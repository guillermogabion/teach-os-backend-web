// TeachOS Admin Panel - Prisma schema
// Dev: SQLite. Swap provider to "postgresql" + DATABASE_URL for production.
// Note: SQLite has no native enum support, so "enum-like" fields are plain
// Strings with the intended values noted in a comment above each one.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------- Auth / RBAC ----------

// RoleName: SUPER_ADMIN | ADMIN | SUPPORT
model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
}

model Permission {
  id    String @id @default(cuid())
  key   String @unique // e.g. "users.delete", "plans.edit"
  label String
  roles Role[]
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  name         String
  isActive     Boolean @default(true)
  isSuspended  Boolean @default(false)
  isBanned     Boolean @default(false)
  roleId       String
  role         Role    @relation(fields: [roleId], references: [id])

  teacherProfile     TeacherProfile?
  subscriptions      Subscription[]
  voucherRedemptions VoucherRedemption[]
  loginLogs          LoginLog[]
  auditLogs          AuditLog[]
  refreshTokens      RefreshToken[]
  notifications      Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent String?
  ip        String?
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ip        String?
  userAgent String?
  success   Boolean
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String // e.g. "PLAN_EDITED", "VOUCHER_CREATED"
  entity    String? // e.g. "SubscriptionPlan"
  entityId  String?
  ip        String?
  userAgent String?
  meta      String? // JSON string of extra context
  createdAt DateTime @default(now())
}

// ---------- Teacher / TeacherOS domain ----------

model TeacherProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  school        String?
  department    String?
  subjects      String? // comma-separated or JSON
  quizCount     Int      @default(0)
  lessonCount   Int      @default(0)
  storageUsedMb Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ---------- Subscriptions & Plans ----------

// billingCycle: MONTHLY | YEARLY | ONE_TIME
model SubscriptionPlan {
  id                 String              @id @default(cuid())
  name               String
  description        String?
  price              Float               @default(0)
  billingCycle       String              @default("MONTHLY") // For simplicity, using string instead of enum
  maxStorageMb       Int                 @default(0)
  maxQuizzes         Int                 @default(0)
  maxLessonPlans     Int                 @default(0)
  isActive           Boolean             @default(true)
  isArchived         Boolean             @default(false)
  featurePermissions FeaturePermission[]
  subscriptions      Subscription[]
  payments           Payment[]
  vouchers           VoucherCode[]       @relation("VoucherPlans")
  licenses           License[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model FeaturePermission {
  id         String           @id @default(cuid())
  planId     String
  plan       SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  featureKey String // e.g. "ocr", "ai_lesson_planner", "pdf_export"
  enabled    Boolean          @default(false)

  @@unique([planId, featureKey])
}

// status: TRIAL | ACTIVE | EXPIRED | CANCELLED | PENDING | GRACE_PERIOD | SUSPENDED
model Subscription {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId    String
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  status    String // Using string for simplicity
  startedAt DateTime         @default(now())
  expiresAt DateTime?
  payments  Payment[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

// ---------- Payments ----------

// provider: GCASH | PAYMONGO | STRIPE | MAYA
// status: PENDING | PAID | EXPIRED | FAILED | REFUNDED
model Payment {
  id               String            @id @default(cuid())
  buyerEmail       String? // for anonymous/reseller purchases with no User account
  buyerName        String?
  planId           String?
  plan             SubscriptionPlan? @relation(fields: [planId], references: [id])
  subscriptionId   String?
  subscription     Subscription?     @relation(fields: [subscriptionId], references: [id])
  amount           Float
  originalAmount   Float? // pre-discount amount; only set when a voucher was applied
  discountApplied  Float             @default(0)
  bonusDaysApplied Int               @default(0) // extra license days granted by a voucher, if any
  voucherId        String?
  voucher          VoucherCode?      @relation(fields: [voucherId], references: [id])
  currency         String            @default("PHP")
  provider         String // Using string for simplicity
  status           String // Using string for simplicity
  receiptUrl       String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

// ---------- Vouchers & Promos ----------

// discountType: PERCENTAGE | FIXED | FREE_TRIAL | FREE_MONTH | FREE_YEAR
model VoucherCode {
  id             String              @id @default(cuid())
  code           String              @unique
  name           String
  description    String?
  discountType   String              @default("PERCENTAGE")
  discountAmount Float               @default(0) // % (0–100) if PERCENTAGE, currency amount if FIXED
  bonusDays      Int                 @default(0) // extra license days on top of the plan's normal duration
  maxUsage       Int                 @default(0) // 0 = unlimited
  currentUsage   Int                 @default(0)
  expiresAt      DateTime?
  isActive       Boolean             @default(true)
  firstTimeOnly  Boolean             @default(false)
  premiumOnly    Boolean             @default(false)
  eligiblePlans  SubscriptionPlan[]  @relation("VoucherPlans")
  redemptions    VoucherRedemption[]
  payments       Payment[]
  campaignId     String?
  campaign       PromoCampaign?      @relation(fields: [campaignId], references: [id])
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
}

// Redemptions are tracked by normalized email, not userId — buyers in
// this flow are anonymous until they activate their License in the app
// (see Payment/License comments elsewhere), so there's usually no User
// row yet to point at. userId is kept around, nullable, for if a real
// account ever does get linked at redemption time.
model VoucherRedemption {
  id         String      @id @default(cuid())
  voucherId  String
  voucher    VoucherCode @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  email      String
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentId  String?
  redeemedAt DateTime    @default(now())

  @@unique([voucherId, email])
}

model PromoCampaign {
  id        String        @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  bannerUrl String?
  isActive  Boolean       @default(true)
  vouchers  VoucherCode[]
  createdAt DateTime      @default(now())
}

// ---------- Notifications & Settings ----------

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  type      String // e.g. "PAYMENT_NEW", "SUBSCRIPTION_EXPIRING"
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ---------- Licenses (mobile app manual/offline activation) ----------
// A License is generated by an admin ahead of time (e.g. printed on a
// receipt, sold via a reseller) and later "claimed" by whoever enters
// the key + their email in the TeacherOS app. That claim is the
// "activation" — it's what ties an otherwise-anonymous key to an account.

// status: UNUSED | ACTIVATED | REVOKED | EXPIRED
model License {
  id          String           @id @default(cuid())
  key         String           @unique
  planId      String
  plan        SubscriptionPlan @relation(fields: [planId], references: [id])
  email       String? // set on activation; null while UNUSED
  status      String           @default("UNUSED") // Using string for simplicity
  maxDevices  Int              @default(1)
  activatedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime         @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
